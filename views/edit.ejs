<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h1>Edit Listing</h1>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST">
        <input type="text" name="listing[title]" value="<%= listing.title %>" required>
        <br>
        <textarea name="listing[description]" required><%= listing.description %></textarea>
        <br>
        <input type="text" name="listing[image]" value="<%= listing.image ? listing.image.url : '' %>" required>
        <br>
        <input type="number" name="listing[price]" value="<%= listing.price %>" required>
        <br>
        <input type="text" name="listing[location]" value="<%= listing.location %>" required>
        <br>
        <input type="text" name="listing[country]" value="<%= listing.country %>" required>
        <br>
        <button type="submit">Update Listing</button>
    </form>
</body>
</html>